# Allo Inventory — Environment Variables
# Copy this file to .env and fill in the values.

# ─── PostgreSQL (Required) ────────────────────────────────────────────────
# Use a hosted Postgres provider: Neon, Supabase, or Railway
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/allo_inventory?sslmode=require"

# ─── Upstash Redis (Optional — enables idempotency) ──────────────────────
# Create a free Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Vercel Cron Secret (Optional — protects cron endpoint in prod) ──────
CRON_SECRET=""
